# Calendly — discovery call booking (date/time picker + email notifications)
# 1. Create a free account at https://calendly.com
# 2. Add an event type (e.g. "Discovery call", 20 minutes)
# 3. Paste the full event URL below, then restart `npm run dev`
# 4. On Netlify: Site settings → Environment variables → add VITE_CALENDLY_URL → redeploy
VITE_CALENDLY_URL=https://calendly.com/samskaranutrition
